<% layout("/layouts/boilerplate") %>

<h3 class="mt-3">Results for "<%= q %>"</h3>

<% if (listings.length === 0) { %>
  <p>No listings found</p>
<% } %>

<div class="row row-cols-3 row-cols-lg-6 row-cols-md-4 row-cols-sm-3 mt-3">
  <% for (let listing of listings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card listing-card h-100">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image">
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text mb-0">
            <b><%= listing.title %></b> <br>
            <span class="price" data-base="<%= listing.price %>">
              ₹ <%= listing.price?.toLocaleString("en-IN") || "0" %> / night
            </span>
            <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<style>
/* Card styling */
.listing-card {
  overflow: hidden;
  border-radius: 10px;
}

/* Card image */
.card-img-top {
  width: 100%;
  object-fit: cover;
  height: 160px; /* default for md+ */
}

/* Responsive heights */
@media (max-width: 575px) {
  .card-img-top {
    height: 90px;
  }
  .card-text {
    font-size: 10px;
  }
}

@media (min-width: 576px) and (max-width: 767px) {
  .card-img-top {
    height: 120px;
  }
  .card-text {
    font-size: 12px;
  }
}

@media (min-width: 768px) {
  .card-img-top {
    height: 160px;
  }
}

/* Tax info hidden by default */
.tax-info {
  display: none;
  font-size: 0.8rem;
  color: gray;
}
</style>
