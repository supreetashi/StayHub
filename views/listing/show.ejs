<% layout("/layouts/boilerplate") %>

  <body>

    <div class="container mt-4">
      <div class="row justify-content-center">

        <div class="card col-12 col-sm-8 col-md-12 col-lg-12 show-card listing-card">
          <h3 class="mb-3">
            <%= listing.title %>
          </h3>

          <img src="<%= listing.image %>" class="card-img-top show-img " alt="listing_image">

          <div class="card-body">

            <p class="card-text">
              <%= listing.description %>
            </p>

            <p class="card-text">
              ₹<%= listing.price.toLocaleString("en-IN") %>
            </p>

            <p class="card-text">
              <%= listing.location %>, <%= listing.country %>
            </p>
          </div>


          <div class="d-flex gap-2 mt-3">

            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
              Edit
            </a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger">Delete</button>
            </form>

          </div>

          <div class="mt-5">
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              <div class="mb-3 mt-3 col-4">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" class="form-range" id="rating" name="review[rating]" min="1" max="5">
              </div>
              <div>
                <label for="comment" class="form-label">Comment</label>
                <textarea class="form-control" id="comment" name="review[comment]" rows="3" required></textarea>
                <div class="invalid-feedback">
                  Please enter a comment.
                </div>
              </div>
              <button type="submit" class="btn btn-success mt-3">Submit Review</button>
            </form>

            <hr />

            <!-- <p><b>Reviews</b></p>
            
              <% for(review of listing.reviews){ %>
                <div class="card">
                  <div class="card-body">
                    <div class="card-body">Jane Doe</div>
                    <p class="card-text"><%= review.comment %></p>
                    <p class="card-text"><%= review.rating %></p>
                  </div>
                </div>
                <% } %> -->
          <p><b>Reviews</b></p>
<div class="row g-3">

<% for (let review of listing.reviews) { %>

<div class="col-md-6">
  <div class="card h-100">

    <div class="card-body d-flex flex-column ">

      <div class="fw-bold card-header mb-2 ">
       ⭐ <%= review.rating %> Stars
      </div>

      <figure class="mb-2 ms-2">
        <blockquote class="blockquote">
          <p><%= review.comment %></p>
        </blockquote>
        <figcaption class="blockquote-footer">
          Jane Doe
        </figcaption>
      </figure>

      <form class="mt-auto ms-2"
        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
        method="POST">
        <button class="btn btn-sm btn-dark mb-2">Delete</button>
      </form>

    </div>

  </div>
</div>

<% } %>

</div>



          </div>

        </div>
      </div>
    </div>

  </body>