<% layout("/layouts/boilerplate") %>
<script>
  const listing = <%- JSON.stringify(listing) %>;
</script>

<style>
  /* Perfect square image and map on small devices */
@media (max-width: 500px) {
.show-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 0.5rem;
}

#map {
  width: 100%;
  aspect-ratio: 1 / 1 !important;
  border-radius: 1rem;
}}
</style>

<body>
  <div class="container mt-4 mb-5 pb-4">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-11 col-md-10 col-lg-8">

        <!-- Title -->
        <h3 class="mb-3 fs-4 fs-md-3"><%= listing.title %></h3>

        <!-- Image -->
        <img 
          src="<%= listing.image.url %>" 
          class="img-fluid rounded-3 w-100 mb-3" 
          style="max-height: 450px; object-fit: cover;" 
          alt="listing_image"
        >

        <!-- Owner -->
        <p class="text-muted mb-1">
          Owned by <i><%= listing.owner.username %></i>
        </p>

        <!-- Description -->
        <p class="mt-2"><%= listing.description %></p>

        <!-- Price -->
        <p class="fw-semibold fs-5">₹<%= listing.price.toLocaleString("en-IN") %> <span class="text-muted fw-normal fs-6">/ night</span></p>

        <!-- Location -->
        <p class="text-muted">
          <i class="fa-solid fa-location-dot me-1"></i>
          <%= listing.location %>, <%= listing.country %>
        </p>

        <hr />

        <!-- Edit / Delete (owner only) -->
        <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
          <div class="d-flex gap-2 mb-4 flex-wrap">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary px-4">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger px-4">Delete</button>
            </form>
          </div>
        <% } %>

        <!-- Leave a Review -->
        <% if(currUser) { %>
          <div class="mt-3 mb-4">
            <h5 class="mb-3">Leave a Review</h5>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              
              <label for="rating" class="form-label">Rating</label>
              <fieldset class="starability-slot mb-3">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>

              <label for="comment" class="form-label">Comment</label>
              <textarea class="form-control" id="comment" name="review[comment]" rows="3" required></textarea>
              <div class="invalid-feedback">Please enter a comment.</div>

              <button type="submit" class="btn btn-success mt-3 w-100 w-sm-auto">Submit Review</button>
            </form>
          </div>
        <% } %>

        <hr />

        <!-- Reviews -->
        <% if(listing.reviews.length > 0) { %>
          <h5 class="mb-3">Reviews</h5>
          <div class="row g-3 mb-4">
            <% for (let review of listing.reviews) { %>
              <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                  <div class="card-body d-flex flex-column">

                    <div class="starability-result mb-2" data-rating="<%= review.rating %>"></div>

                    <figure class="mb-2 flex-grow-1">
                      <blockquote class="blockquote" style="font-size: 0.95rem;">
                        <p><%= review.comment %></p>
                      </blockquote>
                      <figcaption class="blockquote-footer mb-0">
                        @<%= review.author.username %>
                      </figcaption>
                    </figure>

                    <form class="mt-auto"
                      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                      method="POST">
                      <button class="btn btn-sm btn-outline-danger w-100">Delete</button>
                    </form>

                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>

        <!-- Map -->
        <div class="mb-5">
          <h5 class="mb-3">Where you'll be</h5>
          <div id="map" style="width: 100%; height: 400px; border-radius: 1rem;"></div>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/map.js"></script>
</body>